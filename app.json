{
  "expo": {
    "name": "Cart System",
    "slug": "aforro-cart-system",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icons/icon.png",
    "scheme": "aforrocartsystem",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.thesopan21.aforrocartsystem"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/icons/icon.png",
        "backgroundImage": "./assets/icons/icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.thesopan21.aforrocartsystem"
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/icons/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-image",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4b84cad1-5301-46fe-8ac5-13d0f932d382"
      }
    }
  }
}
